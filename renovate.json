{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "timezone": "America/Los_Angeles",
  "schedule": ["on monday"],
  "rebaseWhen": "conflicts-only",
  "separateMajorMinor": false,
  "ignoredLockFiles": ["mise.lock"],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["on monday"]
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^rust-toolchain\\.toml$/"
      ],
      "matchStrings": ["channel = \"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "rust",
      "datasourceTemplate": "github-releases",
      "packageNameTemplate": "rust-lang/rust"
    }
  ],
  "packageRules": [
    {
      "matchManagers": ["cargo"],
      "rangeStrategy": "bump"
    },
    {
      "groupName": "all dependencies",
      "matchPackageNames": [
        "*"
      ]
    }
  ]
}
