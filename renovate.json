{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "timezone": "America/Los_Angeles",
  "schedule": ["on monday"],
  "rebaseWhen": "conflicts-only",
  "separateMajorMinor": false,
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["on monday"]
  },
  "packageRules": [
    {
      "matchManagers": ["cargo"],
      "rangeStrategy": "bump"
    },
    {
      "groupName": "all dependencies",
      "matchPackageNames": [
        "*"
      ]
    }
  ]
}
